# ─────────────────────────────────────────────────────────────────────────
# Al-Ruya WhatsApp Bridge — environment variables
#
# In production: copy to /opt/al-ruya-erp/infra/.env (chmod 600) and fill
# real values. Compose reads from there via --env-file .env. Never commit
# real tokens — the .env file is gitignored.
#
# To register the webhook in Meta Business:
#   1. Set WHATSAPP_VERIFY_TOKEN to any random string you also paste into
#      the Meta dashboard (it must match exactly).
#   2. Webhook URL: https://ibherp.cloud/webhook/whatsapp
#   3. Subscribe to: messages, message_status
# ─────────────────────────────────────────────────────────────────────────

# Service port inside the container (host-routed via docker network only).
PORT=8002

# Random shared secret used by Meta for the GET handshake on /webhook.
# Must match what you paste in the Meta App > WhatsApp > Configuration UI.
WHATSAPP_VERIFY_TOKEN=change-me-to-a-random-32-char-string

# Permanent system-user access token from Meta Business
# (Meta App > WhatsApp > API Setup > Permanent token).
WHATSAPP_ACCESS_TOKEN=

# Numeric WhatsApp Business phone ID (NOT the +964… number itself).
# Find it under: Meta App > WhatsApp > API Setup > Phone numbers.
WHATSAPP_PHONE_ID=

# Internal handoff to the ERP API. Inside docker compose use the service
# name `api`; in dev it can be http://localhost:3000.
ERP_API_URL=http://api:3000

# Service-account token for the ERP. Bridge calls /api/v1/crm/messages
# and similar endpoints with this Bearer token. Mint via the ERP's
# system-user API key flow.
ERP_API_TOKEN=
