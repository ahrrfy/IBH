# ─────────────────────────────────────────────────────────────────────────────
# Al-Ruya WhatsApp Bridge — production .env template
# Copy to .env locally for dev, or set these as ${VAR} in infra/.env on VPS.
# Cloud API setup: https://developers.facebook.com/docs/whatsapp/cloud-api
# ─────────────────────────────────────────────────────────────────────────────

# Listen port (matches Dockerfile EXPOSE and compose healthcheck).
PORT=8002

# Meta verification handshake — must match the value set in the
# WhatsApp Business → App → Webhook → Verify Token field.
# Use a long random string (≥32 chars). Meta will GET /webhook with
# hub.verify_token=<this> exactly once when you save the webhook URL.
WHATSAPP_VERIFY_TOKEN=

# Permanent (System User) access token from Meta Business Manager.
# Temporary 24h tokens will break in production — use System User.
# Generate at: Meta Business Suite → Settings → System Users → Add Token.
# Required scopes: whatsapp_business_messaging, whatsapp_business_management
WHATSAPP_ACCESS_TOKEN=

# Phone Number ID from WhatsApp Business → API Setup.
# This is the numeric "From" sender ID, NOT the phone number itself.
WHATSAPP_PHONE_ID=

# Internal Docker DNS — bridge reaches the API over the erp-internal network.
ERP_API_URL=http://api:3000

# Service-account JWT for /crm/whatsapp/inbox forwarding. Mint a long-lived
# token via the API (or use the seed-created system-bridge user).
# DO NOT commit this — set it in infra/.env on VPS only.
ERP_API_TOKEN=
