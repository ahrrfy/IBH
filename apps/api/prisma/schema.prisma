  // T32 — external delivery company assignment
  deliveryCompanyId String?        @db.Char(26)
  deliveryZoneId    String?        @db.Char(26)
  assignmentReason  String?        @db.VarChar(200) // "auto: cheapest" | "manual" | "fallback: only available"
  externalWaybillNo String?        @db.VarChar(100) // tracking ref from 3rd-party company
  externalStatus    String?        @db.VarChar(100) // last raw status from external API
  shippingCostIqd   Decimal        @default(0) @db.Decimal(18, 3) // what WE pay the company (separate from shippingFeeIqd we charge customer)
  commissionIqd     Decimal        @default(0) @db.Decimal(18, 3) // commission deducted from COD (cached for settlement)
  codSettlementId   String?        @db.Char(26) // set once settled (idempotency guard)
