  @@unique([companyId, number])
  @@index([companyId, status])
  @@index([companyId, driverId])
  @@index([companyId, plannedDate])
  @@index([companyId, deliveryCompanyId, status])
  @@index([deliveryCompanyId, codSettlementId])
  @@map("delivery_orders")
