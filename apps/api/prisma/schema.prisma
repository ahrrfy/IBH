// ============================================================
// WAVE 5 — SUBSCRIPTION & LICENSING SYSTEM (T58)
// ============================================================
// Modern multi-tenant subscription model. The legacy `License`
// model above stays for backward compatibility with the existing
// license-server flow; new code (T59-T71) uses these tables.

enum SubscriptionStatus {
  pending
  trial
  active
  grace
  suspended
  expired
  cancelled
}

enum BillingCycle {
  monthly
  annual
  bundle
}

enum LicenseEventType {
  created
  activated
  trial_started
  trial_extended
  renewed
  upgraded
  downgraded
  suspended
  resumed
  expired
  cancelled
  reinstated
  fingerprint_registered
  fingerprint_revoked
  key_rotated
  payment_received
  payment_failed
  feature_overridden
}

model Plan {
  id              String   @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  code            String   @unique @db.VarChar(50)
  name            String   @db.VarChar(200)
  description     String?
  monthlyPriceIqd Decimal  @db.Decimal(18, 2)
  annualPriceIqd  Decimal  @db.Decimal(18, 2)
  maxUsers        Int?
  maxBranches     Int?
  maxCompanies    Int?     @default(1)
  featureSnapshot Json     @default("{}")
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  isPublic        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  features      PlanFeature[]
  subscriptions Subscription[]

  @@index([isActive, isPublic, sortOrder])
  @@map("plans")
}

model PlanFeature {
  id          String   @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  planId      String   @db.Char(26)
  featureCode String   @db.VarChar(100)
  isEnabled   Boolean  @default(true)
  limits      Json?
  createdAt   DateTime @default(now())

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureCode])
  @@index([featureCode])
  @@map("plan_features")
}

model Subscription {
  id                   String             @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  companyId            String             @db.Char(26)
  planId               String             @db.Char(26)
  status               SubscriptionStatus @default(pending)
  billingCycle         BillingCycle       @default(monthly)
  startedAt            DateTime?
  currentPeriodStartAt DateTime?
  currentPeriodEndAt   DateTime?
  trialStartedAt       DateTime?
  trialEndsAt          DateTime?
  gracePeriodEndsAt    DateTime?
  cancelledAt          DateTime?
  cancellationReason   String?
  priceIqd             Decimal            @default(0) @db.Decimal(18, 2)
  resellerCode         String?            @db.VarChar(50)
  effectiveFeatures    Json               @default("{}")
  notes                String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  createdBy            String?            @db.Char(26)

  plan             Plan                  @relation(fields: [planId], references: [id])
  featureOverrides SubscriptionFeature[]
  licenseKeys      LicenseKey[]
  events           LicenseEvent[]

  @@index([companyId, status])
  @@index([currentPeriodEndAt])
  @@index([gracePeriodEndsAt])
  @@index([trialEndsAt])
  @@map("subscriptions")
}

model SubscriptionFeature {
  id             String    @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  subscriptionId String    @db.Char(26)
  featureCode    String    @db.VarChar(100)
  isEnabled      Boolean   @default(true)
  limits         Json?
  expiresAt      DateTime?
  reason         String?
  createdAt      DateTime  @default(now())
  createdBy      String?   @db.Char(26)

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, featureCode])
  @@index([expiresAt])
  @@map("subscription_features")
}

model LicenseKey {
  id             String    @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  subscriptionId String    @db.Char(26)
  key            String    @unique @db.VarChar(512)
  signatureSha   String    @db.VarChar(64)
  issuedAt       DateTime  @default(now())
  expiresAt      DateTime
  revokedAt      DateTime?
  revokedReason  String?
  maxDevices     Int       @default(1)
  lastSeenAt     DateTime?
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now())
  createdBy      String?   @db.Char(26)

  subscription Subscription          @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  fingerprints HardwareFingerprint[]

  @@index([subscriptionId])
  @@index([expiresAt])
  @@map("license_keys")
}

model HardwareFingerprint {
  id              String    @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  licenseKeyId    String    @db.Char(26)
  fingerprintHash String    @db.VarChar(64)
  deviceLabel     String?   @db.VarChar(200)
  os              String?   @db.VarChar(50)
  appVersion      String?   @db.VarChar(50)
  ipAddress       String?   @db.VarChar(45)
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  isActive        Boolean   @default(true)
  revokedAt       DateTime?
  revokedReason   String?

  licenseKey LicenseKey @relation(fields: [licenseKeyId], references: [id], onDelete: Cascade)

  @@unique([licenseKeyId, fingerprintHash])
  @@index([fingerprintHash])
  @@index([lastSeenAt])
  @@map("hardware_fingerprints")
}

model LicenseEvent {
  id             String           @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  subscriptionId String           @db.Char(26)
  eventType      LicenseEventType
  payload        Json             @default("{}")
  createdAt      DateTime         @default(now())
  createdBy      String?          @db.Char(26)

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt])
  @@index([eventType, createdAt])
  @@map("license_events")
}

// Reorder Points
model ReorderPoint {
  id                  String    @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  variantId           String    @db.Char(26)
  warehouseId         String    @db.Char(26)
  companyId           String    @db.Char(26)
  reorderQty          Decimal   @db.Decimal(18, 3)
  reorderAmount       Decimal   @db.Decimal(18, 3)
  leadTimeDays        Int       @default(7)
  safetyStock         Decimal   @default(0) @db.Decimal(18, 3)
  preferredSupplierId String?   @db.Char(26)
  isAiGenerated       Boolean   @default(false)
  lastCalculatedAt    DateTime?
  updatedAt           DateTime  @updatedAt

  @@unique([variantId, warehouseId])
  @@map("reorder_points")
}

// ─── Notifications (T46) ───────────────────────────────────────────────────
// Per-user notifications dispatched by the Notification Dispatch Engine.
// `data` carries event-specific payload (e.g. invoiceId, amount). `readAt`
// is null until the user marks it read; the in-app bell counts unread rows
// per (userId).
model Notification {
  id        String    @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  companyId String    @db.Char(26)
  userId    String    @db.Char(26)
  eventType String    @db.VarChar(80)
  title     String    @db.VarChar(200)
  body      String    @db.VarChar(2000)
  data      Json      @default("{}")
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([companyId, eventType])
  @@map("notifications")
}

// ─── NotificationPreference (T46) ──────────────────────────────────────────
// Per-user, per-event preference. `channels` is the enabled subset of
// ['inApp','whatsapp','email','sms']. Quiet hours apply to whatsapp/sms only;
// in-app and email always deliver immediately. Times are HH:MM strings in the
// user's local timezone (defer logic computes next-morning UTC delay).
model NotificationPreference {
  id               String   @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  userId           String   @db.Char(26)
  eventType        String   @db.VarChar(80)
  channels         String[] // ['inApp','whatsapp','email','sms']
  quietHoursStart  String?  @db.VarChar(5) // "22:00"
  quietHoursEnd    String?  @db.VarChar(5) // "07:00"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, eventType])
  @@index([userId])
  @@map("notification_preferences")
}

// ─────────────────────────────────────────────────────────────────────────────
// T45 — Omnichannel Order Inbox
//
// Captures inbound messages from messaging channels (WhatsApp, Facebook,
// Instagram) and turns them into draft sales orders via rule-based intent
// extraction (Tier 3 per F5 — no ML for now).
// ─────────────────────────────────────────────────────────────────────────────

model OmnichannelMessage {
  id          String    @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  companyId   String    @db.Char(26)
  channel     String    @db.VarChar(20) // whatsapp | facebook | instagram
  externalId  String    @db.VarChar(120) // provider-side message id (idempotency key)
  fromHandle  String    @db.VarChar(120) // phone / page-scoped id / IG handle
  body        String    @db.Text
  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  draftOrderId String?  @db.Char(26)
  status      String    @default("new") @db.VarChar(20) // new | drafted | approved | rejected | spam

  draftOrder OmnichannelDraftOrder? @relation(fields: [draftOrderId], references: [id])

  @@unique([channel, externalId])
  @@index([companyId, status])
  @@map("omnichannel_messages")
}

model OmnichannelDraftOrder {
  id              String    @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  messageId       String    @db.Char(26)
  customerId      String?   @db.Char(26)
  items           Json      @default("[]") // [{productId, qty, unitPrice}]
  notes           String?   @db.Text
  confidence      Float     @default(0)
  createdAt       DateTime  @default(now())
  approvedAt      DateTime?
  rejectedReason  String?   @db.VarChar(500)

  messages OmnichannelMessage[]

  @@index([messageId])
  @@map("omnichannel_draft_orders")
}

// ============================================================
// T43 — Sales Commissions & Incentives (additive)
// ============================================================

// CommissionPlan: a named plan that groups rules.
// basis indicates what amount the percentage applies to:
//   'sales'  → invoice net amount
//   'margin' → invoice net amount minus COGS
// kind:
//   'flat'   → single % across all sales
//   'tiered' → tiers (CommissionRule rows) with from/to bands
//   'product'→ rules keyed per productId or category
model CommissionPlan {
  id          String   @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  companyId   String   @db.Char(26)
  code        String   @db.VarChar(40)
  nameAr      String   @db.VarChar(200)
  nameEn      String?  @db.VarChar(200)
  basis       String   @default("sales") @db.VarChar(20) // 'sales' | 'margin'
  kind        String   @default("flat")  @db.VarChar(20) // 'flat' | 'tiered' | 'product'
  flatPct     Decimal  @default(0)       @db.Decimal(7, 4) // used when kind='flat'
  validFrom   DateTime @default(now())
  validUntil  DateTime?
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String   @db.Char(26)

  rules       CommissionRule[]
  assignments CommissionAssignment[]
  entries     CommissionEntry[]

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@map("commission_plans")
}

// CommissionRule: rows per plan; meaning depends on plan.kind:
//   'tiered'  → fromAmount/toAmount with pct
//   'product' → productId or categoryId with pct
//   'flat'    → unused (use plan.flatPct)
model CommissionRule {
  id          String   @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  planId      String   @db.Char(26)
  fromAmount  Decimal? @db.Decimal(18, 3)
  toAmount    Decimal? @db.Decimal(18, 3)
  productId   String?  @db.Char(26)
  categoryId  String?  @db.Char(26)
  pct         Decimal  @db.Decimal(7, 4)
  sortOrder   Int      @default(0)

  plan CommissionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@map("commission_rules")
}

// CommissionAssignment: which employee (or external promoter) is on which plan.
// employeeId is preferred; promoterName is for non-employee external partners.
model CommissionAssignment {
  id           String   @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  companyId    String   @db.Char(26)
  planId       String   @db.Char(26)
  employeeId   String?  @db.Char(26)
  promoterName String?  @db.VarChar(200)
  validFrom    DateTime @default(now())
  validUntil   DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  createdBy    String   @db.Char(26)

  plan CommissionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([companyId, employeeId])
  @@index([planId, isActive])
  @@map("commission_assignments")
}

// CommissionEntry: append-only ledger of accruals + clawbacks.
// kind = 'accrual' | 'clawback' | 'adjustment'. amountIqd is signed:
//   accrual   → positive
//   clawback  → negative
//   adjustment→ either sign
// Each entry is posted to the GL via PostingService and journalEntryId is set.
model CommissionEntry {
  id              String   @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  companyId       String   @db.Char(26)
  branchId        String?  @db.Char(26)
  planId          String   @db.Char(26)
  employeeId      String?  @db.Char(26)
  promoterName    String?  @db.VarChar(200)
  kind            String   @db.VarChar(20)            // 'accrual' | 'clawback' | 'adjustment'
  refType         String   @db.VarChar(50)            // 'SalesInvoice' | 'SalesReturn' | 'Manual'
  refId           String   @db.Char(26)
  baseAmountIqd   Decimal  @db.Decimal(18, 3)         // sales/margin amount the % applied to
  pctApplied      Decimal  @db.Decimal(7, 4)
  amountIqd       Decimal  @db.Decimal(18, 3)         // signed
  status          String   @default("accrued") @db.VarChar(20) // 'accrued' | 'paid' | 'reversed'
  journalEntryId  String?  @db.Char(26)
  paidInPayrollId String?  @db.Char(26)
  notes           String?
  createdAt       DateTime @default(now())
  createdBy       String   @db.Char(26)

  plan CommissionPlan @relation(fields: [planId], references: [id])

  @@index([companyId, employeeId, createdAt])
  @@index([companyId, refType, refId])
  @@index([companyId, status])
  @@map("commission_entries")
}

// ─── T42 — Smart Inventory Engine ───────────────────────────────────────────
// Inventory health flags raised by the Q01..Q12 quality rules. One row per
// (variant, warehouse, ruleCode) — re-running the engine UPSERTs the row so
// only the latest state is kept. Append a row to InventoryFlagHistory if you
// need a longitudinal trail later (out of scope for T42).

model InventoryFlag {
  id           String   @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  companyId    String   @db.Char(26)
  variantId    String   @db.Char(26)
  warehouseId  String   @db.Char(26)
  ruleCode     String   @db.VarChar(8)   // Q01 .. Q12
  severity     String   @db.VarChar(16)  // info | warning | critical
  messageAr    String   @db.VarChar(500)
  messageEn    String?  @db.VarChar(500)
  metric       Decimal? @db.Decimal(18, 3)
  threshold    Decimal? @db.Decimal(18, 3)
  payload      Json     @default("{}")
  detectedAt   DateTime @default(now())
  resolvedAt   DateTime?
  resolvedBy   String?  @db.Char(26)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([variantId, warehouseId, ruleCode])
  @@index([companyId, ruleCode, severity])
  @@index([companyId, resolvedAt])
  @@map("inventory_flags")
}

// Audit trail of nightly auto-reorder scans. Each run records what we
// scanned, how many flags were created, and how many draft POs were drafted.

model AutoReorderRun {
  id              String    @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  companyId       String    @db.Char(26)
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  status          String    @db.VarChar(16) // running | completed | failed
  triggeredBy     String?   @db.Char(26)    // userId or null for cron
  scannedSkus     Int       @default(0)
  flagsCreated    Int       @default(0)
  flagsResolved   Int       @default(0)
  draftPosCreated Int       @default(0)
  errorMessage    String?   @db.VarChar(2000)
  payload         Json      @default("{}")

  @@index([companyId, startedAt])
  @@map("auto_reorder_runs")
}

// ============================================================
// HR RECRUITMENT (T51) — JobPosting / Application / InterviewStage / OfferLetter
// State machine: new → screened → interview → offer → hired | rejected
// Public application endpoint is rate-limited and uploads CV reference.
// ============================================================

enum JobPostingStatus {
  draft
  open
  paused
  closed
}

enum ApplicationStatus {
  new
  screened
  interview
  offer
  hired
  rejected
}

enum InterviewOutcome {
  pending
  passed
  failed
  no_show
}

enum OfferLetterStatus {
  draft
  sent
  accepted
  rejected
  withdrawn
  expired
}

/// Job opening that can receive applications. Has public slug for the job board.
model JobPosting {
  id                String           @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  companyId         String           @db.Char(26)
  branchId          String?          @db.Char(26)
  departmentId      String?          @db.Char(26)
  slug              String           @db.VarChar(150)
  titleAr           String           @db.VarChar(200)
  titleEn           String?          @db.VarChar(200)
  descriptionAr     String
  requirementsAr    String?
  /// Comma-separated keywords used by the rule-based auto-screen scorer.
  keywords          String?          @db.VarChar(1000)
  minYearsExperience Int             @default(0)
  employmentType    String           @default("full_time") @db.VarChar(30)
  salaryMinIqd      Decimal?         @db.Decimal(18, 3)
  salaryMaxIqd      Decimal?         @db.Decimal(18, 3)
  location          String?          @db.VarChar(200)
  status            JobPostingStatus @default(draft)
  openedAt          DateTime?
  closedAt          DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  createdBy         String           @db.Char(26)
  updatedBy         String           @db.Char(26)

  applications Application[]

  @@unique([companyId, slug])
  @@index([companyId, status])
  @@map("job_postings")
}

/// Candidate application submitted (publicly or internally). Flows through
/// the recruitment kanban via the ApplicationStatus state machine.
model Application {
  id              String            @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  companyId       String            @db.Char(26)
  jobPostingId    String            @db.Char(26)
  applicantName   String            @db.VarChar(200)
  applicantEmail  String            @db.VarChar(200)
  applicantPhone  String?           @db.VarChar(30)
  yearsExperience Int               @default(0)
  /// Optional URL/key (MinIO object) for the uploaded CV.
  cvUrl           String?           @db.VarChar(500)
  /// Free-text CV body — used by rule-based keyword scorer.
  cvText          String?
  coverLetter     String?
  /// Auto-screen score (0-100). Higher = better keyword + experience match.
  autoScreenScore Int               @default(0)
  status          ApplicationStatus @default(new)
  rejectionReason String?           @db.VarChar(500)
  /// IP of the public submitter (for abuse audit).
  sourceIp        String?           @db.VarChar(64)
  /// User-agent of the public submitter.
  sourceUa        String?           @db.VarChar(300)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  reviewedBy      String?           @db.Char(26)
  reviewedAt      DateTime?

  jobPosting JobPosting        @relation(fields: [jobPostingId], references: [id])
  stages     InterviewStage[]
  offer      OfferLetter?

  @@index([companyId, status])
  @@index([jobPostingId, status])
  @@index([companyId, autoScreenScore])
  @@map("applications")
}

/// One interview round per application. Append rounds as the candidate progresses.
model InterviewStage {
  id            String           @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  companyId     String           @db.Char(26)
  applicationId String           @db.Char(26)
  /// 1-based round number (1 = phone screen, 2 = technical, etc.)
  roundNumber   Int
  scheduledAt   DateTime?
  interviewerId String?          @db.Char(26)
  outcome       InterviewOutcome @default(pending)
  /// Score 0-10 given by the interviewer.
  score         Int?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  application Application @relation(fields: [applicationId], references: [id])

  @@unique([applicationId, roundNumber])
  @@index([companyId])
  @@map("interview_stages")
}

/// Offer extended to a candidate after successful interviews.
model OfferLetter {
  id              String            @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  companyId       String            @db.Char(26)
  applicationId   String            @unique @db.Char(26)
  proposedSalaryIqd Decimal         @db.Decimal(18, 3)
  startDate       DateTime          @db.Date
  expiresAt       DateTime
  status          OfferLetterStatus @default(draft)
  notes           String?
  sentAt          DateTime?
  respondedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  createdBy       String            @db.Char(26)

  application Application @relation(fields: [applicationId], references: [id])

  @@index([companyId, status])
  @@map("offer_letters")
}
