  @@map("delivery_status_logs")
}

// ============================================================
// T32 — EXTERNAL DELIVERY COMPANIES
// ============================================================
//   - DeliveryCompany: internal driver pool + 3rd-party couriers
//   - DeliveryZone:    geographic hierarchy (country/governorate/city/district)
//   - DeliveryCompanyRate: pricing matrix per (company × zone)
//   - CodSettlement:   periodic COD batch reconciliation
// All four match migrations/0010_delivery_companies/migration.sql byte-for-byte.

model DeliveryCompany {
  id                 String              @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  companyId          String              @db.Char(26)
  code               String              @db.VarChar(20)
  nameAr             String              @db.VarChar(200)
  nameEn             String?             @db.VarChar(200)
  type               DeliveryCompanyType @default(external)
  contactPerson      String?             @db.VarChar(200)
  phone              String?             @db.VarChar(20)
  whatsapp           String?             @db.VarChar(20)
  email              String?             @db.VarChar(200)
  address            String?
  commissionPct      Decimal             @default(0) @db.Decimal(5, 2) // % of COD kept by company
  flatFeePerOrderIqd Decimal             @default(0) @db.Decimal(18, 3) // optional flat fee added to commission
  supportsCod        Boolean             @default(true)
  codHoldingDays     Int                 @default(7) // days before settlement is due
  minOrderValueIqd   Decimal?            @db.Decimal(18, 3)
  maxOrderValueIqd   Decimal?            @db.Decimal(18, 3)
  // cached scorecard (recomputed by autopilot cron — fast read for assignment)
  totalDispatched    Int                 @default(0)
  totalDelivered     Int                 @default(0)
  totalFailed        Int                 @default(0)
  totalReturned      Int                 @default(0)
  successRatePct     Decimal             @default(0) @db.Decimal(5, 2)
  avgDeliveryHours   Decimal             @default(0) @db.Decimal(8, 2)
  lastScoredAt       DateTime?
  isActive           Boolean             @default(true)
  autoSuspendedAt    DateTime? // set when scorecard cron suspends
  autoSuspendReason  String?             @db.VarChar(500)
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  createdBy          String              @db.Char(26)
  updatedBy          String              @db.Char(26)
  deletedAt          DateTime?
  deletedBy          String?             @db.Char(26)

  rates          DeliveryCompanyRate[]
  deliveries     DeliveryOrder[]
  codSettlements CodSettlement[]

  @@unique([companyId, code])
  @@index([companyId, isActive, type])
  @@map("delivery_companies")
}

model DeliveryZone {
  id        String   @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  companyId String   @db.Char(26)
  code      String   @db.VarChar(40)
  nameAr    String   @db.VarChar(200)
  nameEn    String?  @db.VarChar(200)
  parentId  String?  @db.Char(26)
  level     Int      @default(0) // 0=country, 1=governorate, 2=city, 3=district
  city      String?  @db.VarChar(100) // denormalized for fast match against DeliveryOrder.deliveryCity
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String   @db.Char(26)
  updatedBy String   @db.Char(26)

  parent     DeliveryZone?         @relation("DeliveryZoneTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   DeliveryZone[]        @relation("DeliveryZoneTree")
  rates      DeliveryCompanyRate[]
  deliveries DeliveryOrder[]

  @@unique([companyId, code])
  @@index([companyId, city])
  @@index([companyId, parentId])
  @@map("delivery_zones")
}

model DeliveryCompanyRate {
  id                String    @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  deliveryCompanyId String    @db.Char(26)
  deliveryZoneId    String    @db.Char(26)
  baseFeeIqd        Decimal   @db.Decimal(18, 3)
  perKgIqd          Decimal   @default(0) @db.Decimal(18, 3)
  minFeeIqd         Decimal?  @db.Decimal(18, 3)
  maxFeeIqd         Decimal?  @db.Decimal(18, 3)
  estimatedHours    Int       @default(24)
  isActive          Boolean   @default(true)
  validFrom         DateTime  @default(now())
  validUntil        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String    @db.Char(26)
  updatedBy         String    @db.Char(26)

  deliveryCompany DeliveryCompany @relation(fields: [deliveryCompanyId], references: [id], onDelete: Cascade)
  deliveryZone    DeliveryZone    @relation(fields: [deliveryZoneId], references: [id], onDelete: Cascade)

  @@unique([deliveryCompanyId, deliveryZoneId], map: "delivery_company_rates_company_zone_key")
  @@index([deliveryZoneId, isActive])
  @@map("delivery_company_rates")
}

model CodSettlement {
  id                   String              @id @default(dbgenerated("gen_ulid()")) @db.Char(26)
  companyId            String              @db.Char(26)
  deliveryCompanyId    String              @db.Char(26)
  number               String              @db.VarChar(50)
  periodStart          DateTime
  periodEnd            DateTime
  totalCodCollectedIqd Decimal             @default(0) @db.Decimal(18, 3)
  totalCommissionIqd   Decimal             @default(0) @db.Decimal(18, 3)
  totalShippingCostIqd Decimal             @default(0) @db.Decimal(18, 3)
  netDueIqd            Decimal             @default(0) @db.Decimal(18, 3) // collected − commission − shippingCost
  deliveriesCount      Int                 @default(0)
  status               CodSettlementStatus @default(draft)
  proposedJeId         String?             @db.Char(26) // draft journal entry awaiting approval
  postedJeId           String?             @db.Char(26) // approved + posted journal entry
  approvedBy           String?             @db.Char(26)
  approvedAt           DateTime?
  paidAt               DateTime?
  paymentRef           String?             @db.VarChar(100)
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  createdBy            String              @db.Char(26)

  deliveryCompany DeliveryCompany @relation(fields: [deliveryCompanyId], references: [id], onDelete: Restrict)
  deliveries      DeliveryOrder[]

  @@unique([companyId, number])
  @@unique([deliveryCompanyId, periodStart, periodEnd], map: "cod_settlements_company_period_key")
  @@index([companyId, status])
  @@index([deliveryCompanyId, status])
  @@map("cod_settlements")
}

