{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Al-Ruya POS",
  "version": "1.0.0",
  "identifier": "iq.al-ruya.pos",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "الرؤية العربية · نقطة البيع",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.al-ruya.iq ipc: http://ipc.localhost; img-src 'self' data: https://*; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "category": "Business",
    "copyright": "© 2026 شركة الرؤية العربية للتجارة",
    "shortDescription": "نقطة البيع للرؤية العربية",
    "longDescription": "نظام نقطة البيع (POS) لشركة الرؤية العربية — يعمل offline بقاعدة SQLite مشفَّرة"
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:pos.db"]
    }
  }
}
