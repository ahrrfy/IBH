{
  "name": "@al-ruya/license-server",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone license issuance + heartbeat server (RSA-2048 signed licenses, 30-day grace)",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "issue": "tsx src/cli/issue.ts",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "zod": "^3.23.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
