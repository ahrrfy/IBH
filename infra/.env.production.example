# ─────────────────────────────────────────────────────────────────────────────
# Al-Ruya ERP — Production environment template
# Copy to .env on the VPS, fill in real secrets, NEVER commit the filled file.
# Generate strong secrets with:  openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_random_password

# ── JWT (auth) ──────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_at_least_32_random_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── MinIO (S3 object storage) ───────────────────────────────────────────────
MINIO_ACCESS_KEY=alruya_admin
MINIO_SECRET_KEY=CHANGE_ME_strong_random_password

# ── App URL (used for CORS, links in emails, etc.) ──────────────────────────
# First deploy: use VPS IP. Switch to https://erp.your-domain.com once SSL is ready.
APP_URL=http://187.124.183.140
CORS_ORIGINS=http://187.124.183.140

# ── Optional: AI Brain (only if running --profile ai) ──────────────────────
AI_BRAIN_API_KEY=
AI_VERSION=latest

# ── Optional: WhatsApp Bridge (only if running --profile whatsapp) ─────────
WHATSAPP_BRIDGE_TOKEN=
WA_VERSION=latest

# ── Optional: Backups (Restic) ──────────────────────────────────────────────
RESTIC_REPOSITORY=/backups/restic-repo
RESTIC_PASSWORD=CHANGE_ME_strong_random_password

# ── Optional: Grafana (only if running --profile monitoring) ───────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── Optional: License server (Wave 6) ───────────────────────────────────────
LICENSE_ADMIN_TOKEN=
