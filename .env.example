# ─────────────────────────────────────────────────────────────────────────────
# Al-Ruya ERP — Environment Variables
# Copy to .env.local (development) or .env (production)
# NEVER commit real values — this file is the template only
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database (PostgreSQL 16) ──────────────────────────────────────────────────
DATABASE_URL="postgresql://erp_app:CHANGE_ME@postgres:5432/alruya_erp?schema=public&sslmode=prefer"
DATABASE_SHADOW_URL="postgresql://erp_app:CHANGE_ME@postgres:5432/alruya_erp_shadow?schema=public"

# Direct connection for Prisma migrations (bypasses pgBouncer if used)
DIRECT_DATABASE_URL="postgresql://erp_app:CHANGE_ME@postgres:5432/alruya_erp?schema=public"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_USE_LONG_RANDOM_STRING_64_CHARS_MIN
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── MinIO (S3-compatible storage) ────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET_DOCUMENTS=erp-documents
MINIO_BUCKET_ATTACHMENTS=erp-attachments
MINIO_BUCKET_EXPORTS=erp-exports

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://erp.al-ruya.iq
FRONTEND_URL=https://app.al-ruya.iq
STOREFRONT_URL=https://store.al-ruya.iq

# ── Cors ──────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed
CORS_ORIGINS=https://app.al-ruya.iq,https://store.al-ruya.iq

# ── Throttle ──────────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
THROTTLE_AUTH_LIMIT=10

# ── AI Brain (Python FastAPI) ─────────────────────────────────────────────────
AI_BRAIN_URL=http://ai-brain:8001
AI_BRAIN_API_KEY=CHANGE_ME

# ── Email (Postfix local) ─────────────────────────────────────────────────────
SMTP_HOST=postfix
SMTP_PORT=587
SMTP_USER=noreply@al-ruya.iq
SMTP_PASS=CHANGE_ME
SMTP_FROM="الرؤية العربية <noreply@al-ruya.iq>"

# ── WhatsApp Bridge ──────────────────────────────────────────────────────────
WHATSAPP_BRIDGE_URL=http://whatsapp-bridge:3100
WHATSAPP_BRIDGE_TOKEN=CHANGE_ME

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── Backup (Restic) ──────────────────────────────────────────────────────────
RESTIC_PASSWORD=CHANGE_ME_USE_STRONG_PASSPHRASE
RESTIC_REPOSITORY=/backups/restic-repo

# ── Encryption ────────────────────────────────────────────────────────────────
# Used for license file signing, sensitive config encryption
ENCRYPTION_KEY=CHANGE_ME_32_BYTES_HEX

# ── Seed: System Owner (seed-bootstrap.ts) ────────────────────────────────────
# Required to create the single permanent system owner account on first boot.
# OWNER_PASSWORD must be ≥12 chars. If unset → seed-bootstrap skips owner creation.
OWNER_USERNAME=ahrrfy
OWNER_EMAIL=owner@al-ruya.iq
OWNER_PASSWORD=CHANGE_ME_MIN_12_CHARS

# ── Seed: Test Admin (seed.ts + seed-bootstrap.ts) ────────────────────────────
# Optional: creates a test admin account in dev/staging. Both must be set
# together to actually create the admin (per security hardening 3b15e16).
# SEED_ADMIN_PASSWORD must be ≥12 chars and not contain "CHANGE_ME".
SEED_ADMIN_EMAIL=admin@al-ruya.iq
SEED_ADMIN_PASSWORD=CHANGE_ME_MIN_12_CHARS

# Bootstrap admin used by docker-compose.bootstrap.yml on first run.
# Same constraints as SEED_ADMIN_*.
ADMIN_EMAIL=admin@al-ruya.iq
ADMIN_PASSWORD=CHANGE_ME_MIN_12_CHARS

# ── Test Admin (auth.e2e-spec.ts) ─────────────────────────────────────────────
# Used by e2e tests to log in. If unset → auth.e2e tests skip the success
# scenario (they still verify wrong-password and unauthenticated paths).
TEST_ADMIN_EMAIL=admin@al-ruya.iq
TEST_ADMIN_PASSWORD=CHANGE_ME_MIN_12_CHARS

# ── License Server (apps/license-server) ──────────────────────────────────────
# RSA-2048 keypair for signing/verifying license files. Generate with:
#   openssl genpkey -algorithm RSA -out license.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in license.pem -pubout -out license-pub.pem
# Pass as multi-line strings (escape \n) or as base64-encoded PEM.
LICENSE_PRIVATE_KEY=
LICENSE_PUBLIC_KEY=
LICENSE_GRACE_PERIOD_DAYS=30

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Set to 'debug' in dev to see SQL queries (PrismaService respects NODE_ENV=development)
